# AWS Account
AWS_ACCOUNT=123456789012
AWS_REGION=us-east-1          # S3, ECR, IAM, SSM all live here
TRAINING_REGION=us-west-2     # EC2 training instances run here

# AMI (Deep Learning OSS Nvidia Driver AMI GPU PyTorch 2.7 Ubuntu 22.04)
# Find for your region: aws ec2 describe-images --owners amazon --filters "Name=name,Values=Deep Learning OSS Nvidia Driver AMI GPU PyTorch 2.7*Ubuntu 22.04*"
AMI_ID=ami-xxxxxxxxxxxxxxxxx

# Subnets in TRAINING_REGION (one per AZ, used for capacity fallback)
SUBNET_AZ1=subnet-xxxxxxxxxxxxxxxxx
SUBNET_AZ2=subnet-xxxxxxxxxxxxxxxxx
SUBNET_AZ3=subnet-xxxxxxxxxxxxxxxxx
SUBNET_AZ4=subnet-xxxxxxxxxxxxxxxxx

# Training dataset
DATASET_PREFIX=datasets/my-character-v1/
TRIGGER_WORD=MYCHARACTER
LOCAL_DATASET_PATH=/path/to/your/local/images
